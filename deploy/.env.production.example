# =============================================================================
# Finance Agents Platform — Production Environment Variables
# =============================================================================
# Copy this file to /opt/finance-agents/.env.production and fill in values.
#
#   cp deploy/.env.production.example .env.production
#   chmod 600 .env.production
#
# NEVER commit .env.production to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Django Core
# ---------------------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings
DJANGO_SECRET_KEY=CHANGE_ME_generate_with_python_c_from_django_core_management_utils_import_get_random_secret_key_print_get_random_secret_key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=20.244.26.58,finance-agents.yourdomain.com,localhost
CSRF_TRUSTED_ORIGINS=http://20.244.26.58,https://finance-agents.yourdomain.com

# ---------------------------------------------------------------------------
# Database — MySQL (separate production schema)
# ---------------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=finance_agents_prod
DB_USER=finance_agents_prod_user
DB_PASSWORD=CHANGE_ME_strong_password_here

# ---------------------------------------------------------------------------
# Redis & Celery
# ---------------------------------------------------------------------------
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_TASK_ALWAYS_EAGER=False

# ---------------------------------------------------------------------------
# Azure OpenAI (LLM for agents)
# ---------------------------------------------------------------------------
LLM_PROVIDER=azure_openai
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT=
LLM_MODEL_NAME=gpt-4o
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# ---------------------------------------------------------------------------
# Azure Document Intelligence (OCR extraction)
# ---------------------------------------------------------------------------
AZURE_DI_ENDPOINT=
AZURE_DI_KEY=

# ---------------------------------------------------------------------------
# Azure Blob Storage (document storage)
# ---------------------------------------------------------------------------
AZURE_BLOB_CONNECTION_STRING=
AZURE_BLOB_CONTAINER_NAME=finance-agents

# ---------------------------------------------------------------------------
# Reconciliation Defaults
# ---------------------------------------------------------------------------
DEFAULT_QTY_TOLERANCE_PCT=2.0
DEFAULT_PRICE_TOLERANCE_PCT=1.0
DEFAULT_AMOUNT_TOLERANCE_PCT=1.0
EXTRACTION_CONFIDENCE_THRESHOLD=0.75

# ---------------------------------------------------------------------------
# Email Integration Webhook Security
# ---------------------------------------------------------------------------
# Provider webhook requests must include header: X-Webhook-Token
EMAIL_WEBHOOK_SHARED_SECRET=

# ---------------------------------------------------------------------------
# Langfuse (LLM tracing)
# ---------------------------------------------------------------------------
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://us.cloud.langfuse.com
LANGFUSE_ENVIRONMENT=production

# ---------------------------------------------------------------------------
# Gunicorn
# ---------------------------------------------------------------------------
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=300

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
APP_ENV=production
