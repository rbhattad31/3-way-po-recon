# =============================================================================
# Finance Agents Platform — Flower (Celery Monitor) systemd Service
# =============================================================================
# Install:
#   sudo cp /opt/finance-agents/deploy/finance-agents-flower.service /etc/systemd/system/
#   sudo systemctl daemon-reload
#   sudo systemctl enable finance-agents-flower
#   sudo systemctl start finance-agents-flower
#
# Access via Nginx proxy at: http://<server-ip>/flower/
# =============================================================================

[Unit]
Description=Finance Agents Flower (Celery Monitoring)
After=network.target redis-server.service finance-agents-celery.service

[Service]
Type=simple
User=financeagents
Group=financeagents
WorkingDirectory=/opt/finance-agents
EnvironmentFile=/opt/finance-agents/.env.production

ExecStart=/opt/finance-agents/venv/bin/celery \
    -A config \
    flower \
    --port=5555 \
    --address=127.0.0.1 \
    --url_prefix=flower \
    --persistent=True \
    --db=/opt/finance-agents/run/flower.db \
    --max_tasks=10000 \
    --purge_offline_workers=60 \
    --auto_refresh=True \
    --basic_auth=admin:FinanceAgents2026!

Restart=always
RestartSec=10
KillMode=mixed

# Security hardening
PrivateTmp=true
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
