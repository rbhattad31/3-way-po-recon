# =============================================================================
# Finance Agents Platform — Gunicorn systemd Service
# =============================================================================
# Install:
#   sudo cp /opt/finance-agents/deploy/finance-agents-gunicorn.service /etc/systemd/system/
#   sudo systemctl daemon-reload
#   sudo systemctl enable finance-agents-gunicorn
#   sudo systemctl start finance-agents-gunicorn
# =============================================================================

[Unit]
Description=Finance Agents Gunicorn Application Server
After=network.target redis-server.service
Requires=redis-server.service

[Service]
Type=notify
User=financeagents
Group=financeagents
WorkingDirectory=/opt/finance-agents
EnvironmentFile=/opt/finance-agents/.env.production

ExecStart=/opt/finance-agents/venv/bin/gunicorn \
    --workers 4 \
    --threads 2 \
    --worker-class gthread \
    --worker-tmp-dir /dev/shm \
    --bind unix:/opt/finance-agents/run/gunicorn.sock \
    --timeout 300 \
    --graceful-timeout 30 \
    --max-requests 1000 \
    --max-requests-jitter 50 \
    --access-logfile /opt/finance-agents/logs/gunicorn-access.log \
    --error-logfile /opt/finance-agents/logs/gunicorn-error.log \
    --log-level info \
    config.wsgi:application

ExecReload=/bin/kill -s HUP $MAINPID

Restart=always
RestartSec=5
KillMode=mixed
TimeoutStopSec=30

# Security hardening
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/opt/finance-agents/run /opt/finance-agents/logs /opt/finance-agents/media /opt/finance-agents/static
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
